# ============================================================
# AerialClaw Environment Configuration
# AerialClaw 环境配置
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# 复制此文件为 .env 后填入你的配置：
#   cp .env.example .env
# ============================================================

# ── Active Provider ──────────────────────────────────────────
# Which LLM provider to use by default: openai / ollama_local / deepseek / moonshot / zhipu
# 默认使用哪个 LLM 服务: openai / ollama_local / deepseek / moonshot / zhipu
ACTIVE_PROVIDER=openai

# ── LLM (OpenAI-compatible) ─────────────────────────────────
# Works with OpenAI, Azure, or any compatible API proxy.
# 兼容 OpenAI、Azure 或任何兼容接口的代理。
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-llm-api-key-here
LLM_MODEL=gpt-4o

# ── VLM (Vision Language Model) ─────────────────────────────
# Used for camera image analysis. Can be same as LLM or a different endpoint.
# 用于摄像头图像分析，可与 LLM 相同或使用不同的端点。
VLM_BASE_URL=https://api.openai.com/v1
VLM_API_KEY=your-vlm-api-key-here
VLM_MODEL=gpt-4o

# ── Ollama (Local) ──────────────────────────────────────────
# If using local models via Ollama. No API key needed.
# 使用本地 Ollama 模型时配置，无需 API key。
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# ── DeepSeek ────────────────────────────────────────────────
# DEEPSEEK_API_KEY=your-deepseek-key-here

# ── Moonshot (Kimi) ─────────────────────────────────────────
# MOONSHOT_API_KEY=your-moonshot-key-here

# ── Zhipu (GLM) ─────────────────────────────────────────────
# ZHIPU_API_KEY=your-zhipu-key-here

# ── MAVSDK ──────────────────────────────────────────────────
# MAVSDK_PORT=50051
# MAVSDK_ADDR=udp://:14540

# ── Server ──────────────────────────────────────────────────
# SERVER_HOST=0.0.0.0
# SERVER_PORT=5001

# ── Simulator Adapter ────────────────────────────────────────
# Options: px4 / airsim / mock
# px4:    PX4 SITL via MAVSDK (default)
# airsim: AirSim SimpleFlight via pure-socket msgpack-rpc
# mock:   No hardware, for UI testing
SIM_ADAPTER=px4

# AirSim connection (used when SIM_ADAPTER=airsim)
# For remote server: set up SSH tunnel first:
#   ssh -fNT -L 41451:localhost:41451 -p <PORT> user@host
# Then set AIRSIM_HOST=127.0.0.1
AIRSIM_HOST=127.0.0.1
AIRSIM_PORT=41451
AIRSIM_VEHICLE=drone_1
